generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum UserRole {
  USER
  ADMIN
}

enum ScheduleVisibility {
  PRIVATE
  UNLISTED
  PUBLIC
}

enum CourseStateStatus {
  PLANNED
  COMPLETED
  IN_PROGRESS
  WAIVED
}

model User {
  id                  String               @id @default(cuid())
  email               String               @unique
  passwordHash        String
  displayName         String
  majorCode           String?
  isEmailVerified     Boolean              @default(false)
  role                UserRole             @default(USER)
  createdAt           DateTime             @default(now())
  updatedAt           DateTime             @updatedAt
  verificationTokens  VerificationToken[]
  passwordResetTokens PasswordResetToken[]
  courseStates        UserCourseState[]
  schedules           Schedule[]
  courseReviews       CourseReview[]
  professorReviews    ProfessorReview[]
  scheduleComments    ScheduleComment[]
}

model VerificationToken {
  id        String   @id @default(cuid())
  userId    String
  tokenHash String
  expiresAt DateTime
  usedAt    DateTime?
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model PasswordResetToken {
  id        String   @id @default(cuid())
  userId    String
  tokenHash String
  expiresAt DateTime
  usedAt    DateTime?
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Major {
  id           String             @id @default(cuid())
  code         String             @unique
  name         String
  description  String?
  requirements MajorRequirement[]
}

model MajorRequirement {
  id              String   @id @default(cuid())
  majorId         String
  courseId        String?
  requirementKey  String
  label           String
  category        String
  recommendedTerm Int?
  isRequired      Boolean  @default(true)
  major           Major    @relation(fields: [majorId], references: [id], onDelete: Cascade)
  course          Course?  @relation(fields: [courseId], references: [id])
}

model Course {
  id              String               @id @default(cuid())
  courseCode      String               @unique
  title           String
  department      String?
  catalogNo       String?
  description     String?
  unitsMin        Float?
  unitsMax        Float?
  prerequisites   CoursePrerequisite[] @relation("CourseToPrereq")
  dependentOn     CoursePrerequisite[] @relation("PrereqToCourse")
  offerings       CourseOffering[]
  hubAreas        CourseHubArea[]
  courseStates    UserCourseState[]
  courseReviews   CourseReview[]
  requirements    MajorRequirement[]
}

model CoursePrerequisite {
  id         String  @id @default(cuid())
  courseId   String
  prereqId   String
  groupLabel String?
  isCoreq    Boolean @default(false)
  course     Course  @relation("CourseToPrereq", fields: [courseId], references: [id], onDelete: Cascade)
  prereq     Course  @relation("PrereqToCourse", fields: [prereqId], references: [id], onDelete: Cascade)

  @@unique([courseId, prereqId, groupLabel, isCoreq])
}

model HubArea {
  id      String          @id @default(cuid())
  code    String          @unique
  label   String
  courses CourseHubArea[]
}

model CourseHubArea {
  id        String  @id @default(cuid())
  courseId  String
  hubAreaId String
  course    Course  @relation(fields: [courseId], references: [id], onDelete: Cascade)
  hubArea   HubArea @relation(fields: [hubAreaId], references: [id], onDelete: Cascade)

  @@unique([courseId, hubAreaId])
}

model CourseOffering {
  id              String  @id @default(cuid())
  courseId        String
  termCode        String
  classNumber     String?
  sectionCode     String?
  displayTitle    String?
  session         String?
  units           String?
  status          String?
  campus          String?
  instructionMode String?
  instructor      String?
  days            String?
  startTime       String?
  endTime         String?
  dates           String?
  rawJson         Json?
  scheduleEntries ScheduleEntry[]
  course          Course  @relation(fields: [courseId], references: [id], onDelete: Cascade)
}

model UserCourseState {
  id        String            @id @default(cuid())
  userId    String
  courseId  String
  status    CourseStateStatus
  termCode  String?
  user      User              @relation(fields: [userId], references: [id], onDelete: Cascade)
  course    Course            @relation(fields: [courseId], references: [id], onDelete: Cascade)
  createdAt DateTime          @default(now())
  updatedAt DateTime          @updatedAt

  @@unique([userId, courseId], name: "userId_courseId")
  
}
model Schedule {
  id          String   @id @default(cuid())
  userId      String
  title       String
  description String?
  visibility  ScheduleVisibility @default(PRIVATE)
  termCode    String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  user      User @relation(fields: [userId], references: [id], onDelete: Cascade)
  items     ScheduleEntry[]
  comments  ScheduleComment[]
}
model ScheduleEntry {
  id               String         @id @default(cuid())
  scheduleId       String
  courseOfferingId String
  note             String?

  schedule         Schedule       @relation(fields: [scheduleId], references: [id], onDelete: Cascade)
  offering         CourseOffering @relation(fields: [courseOfferingId], references: [id], onDelete: Cascade)
}

model CourseReview {
  id        String   @id @default(cuid())
  userId    String
  courseId  String
  rating    Int
  comment   String?
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  course    Course   @relation(fields: [courseId], references: [id], onDelete: Cascade)
}

model Professor {
  id             String            @id @default(cuid())
  name           String
  normalizedName String            @unique
  department     String?
  rmpId          String?
  reviews        ProfessorReview[]
}

model ProfessorReview {
  id          String    @id @default(cuid())
  userId      String
  professorId String
  rating      Int
  comment     String?
  createdAt   DateTime  @default(now())
  user        User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  professor   Professor @relation(fields: [professorId], references: [id], onDelete: Cascade)
}

model ScheduleComment {
  id         String   @id @default(cuid())
  userId     String
  scheduleId String
  body       String
  createdAt  DateTime @default(now())
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  schedule   Schedule @relation(fields: [scheduleId], references: [id], onDelete: Cascade)
}
